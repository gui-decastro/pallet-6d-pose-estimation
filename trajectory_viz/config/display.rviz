        X: 0
        Y: 0
        Z: 0.05000000074505806
      Pose Color: 100; 200; 255
      Pose Style: None
      Radius: 0.029999999329447746
      Shaft Diameter: 0.05000000074505806
      Shaft Length: 0.15000000596046448
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /trajectory
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: TapeRays
      Namespaces:
        tape_rays: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /tape_rays
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: CameraFrustum
      Namespaces:
        camera_frustum: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /camera_frustum
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: PalletEstimated
      Namespaces:
        pallet_est: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /pallet_estimated
      Value: true
    - Class: rviz_default_plugins/MarkerArray
      Enabled: true
      Name: PalletGroundTruth
      Namespaces:
        {}
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /pallet_ground_truth
      Value: true
    - Class: rviz_default_plugins/TF
      Enabled: true
      Filter (blacklist): ""
      Filter (whitelist): ""
      Frame Timeout: 15
      Frames:
        All Enabled: true
        forklift:
          Value: true
        pallet_est:
          Value: true
        pickup:
          Value: true
        world:
          Value: true
